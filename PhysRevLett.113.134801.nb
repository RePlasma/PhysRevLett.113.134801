      SuperscriptBox["10", 
       RowBox[{"-", "19"}]]}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"[", "C", "]"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", 
