Cell[CellGroupData[{

Cell["\[Eta] factor for the two envelopes (+Gaussian)", "Chapter",
 CellChangeTimes->{{3.877386140236671*^9, 3.877386141243288*^9}, {
  3.877389340261024*^9, 3.877389340696511*^9}, {3.880101855925767*^9, 
  3.880101865048532*^9}, {3.987240440858323*^9, 
  3.987240444476144*^9}},ExpressionUUID->"7f4303c2-5ffd-442c-88c8-\
d0bb080b7288"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "t", ",", "\[Tau]", ",", "\[Tau]0", ",", "aPoly", ",", "aSin2", ",", 
   "aGauss", ",", "intPoly", ",", "intSin2", ",", "intGauss"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Tau]0", "=", "1"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"[", "]"}], " ", "normalize", " ", "all", " ", "times", " ", "to",
     " ", "\[Tau]0"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Tau]", "=", " ", 
    RowBox[{"t", "/", "\[Tau]0"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"aPoly", "=", 
    RowBox[{
     RowBox[{"10", 
      SuperscriptBox["\[Tau]", "3"]}], "-", 
     RowBox[{"15", 
      SuperscriptBox["\[Tau]", "4"]}], "+", 
     RowBox[{"6", 
      SuperscriptBox["\[Tau]", "5"]}]}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"polynomial", " ", 
     RowBox[{"envelope", ".", " ", "instead"}], " ", "of", " ", "using", " ", 
     "\[Tau]"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Sqrt]", "2"}], " ", 
      RowBox[{"t", "/", "\[Tau]0"}], " ", "as", " ", "in", " ", "the", " ", 
      "paper", " ", 
      RowBox[{"(", 
       RowBox[{
       "which", " ", "would", " ", "give", " ", "incorrect", " ", 
        "integrals"}], ")"}], " ", "we", " ", "use", " ", "simply", " ", 
      "\[Tau]"}], "=", 
     RowBox[{
      RowBox[{"t", "/", "\[Tau]0"}], " ", "to", " ", "be", " ", "able", " ", 
      "to", " ", "compare", " ", "between", " ", "the", " ", "two", " ", 
      "envelopes"}]}]}], "  ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"aSin2", "=", 
    SuperscriptBox[
     RowBox[{"Sin", "[", 
      FractionBox[
       RowBox[{"\[Pi]", " ", "t"}], 
       RowBox[{"2", "\[Tau]0"}]], "]"}], "2"]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    SuperscriptBox["sin", "2"], " ", "envelope"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"aGauss", "=", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "4"}], 
      RowBox[{"Log", "[", "2", "]"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         FractionBox[
          RowBox[{" ", "t"}], "\[Tau]0"]}], ")"}], "2"]}], "]"}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    SuperscriptBox["sin", "2"], " ", "envelope"}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "plot", " ", "the", " ", "three", " ", "envelopes", " ", "with", " ", 
     "same", " ", "fwhm", " ", "in", " ", "field"}], ",", " ", 
    RowBox[{"not", " ", "intensity"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"aPoly", ",", "aSin2", ",", "aGaus", ",", "0.5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "\[Tau]0"}], "}"}], ",", 
    RowBox[{"Frame", "\[Rule]", "True"}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "\"\<FLD a0(t)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Polynomial\>\"", ",", 
       "\"\<\!\(\*SuperscriptBox[\(Sin\), \(2\)]\)\>\"", ",", 
       "\"\<Gauss\>\""}], "}"}]}]}], "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"plot", " ", "also", " ", "intensity"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"aPoly", "^", "2"}], ",", 
      RowBox[{"aSin2", "^", "2"}], ",", 
      RowBox[{"aGaus", "^", "2"}], ",", "0.5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "\[Tau]0"}], "}"}], ",", 
    RowBox[{"Frame", "\[Rule]", "True"}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "\"\<Intensity a0(t)^2\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<Polynomial\>\"", ",", 
       "\"\<\!\(\*SuperscriptBox[\(Sin\), \(2\)]\)\>\"", ",", 
       "\"\<Gauss\>\""}], "}"}]}]}], "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "the", " ", "k", " ", "factor", " ", "will", " ", "be", " ", 
     "proportional", " ", "to", " ", "a", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", "t", ")"}], "2"], ".", " ", "since"}], " ", "the", " ", 
     "envelopes", " ", "are", " ", "symmetric"}], ",", " ", 
    RowBox[{
     RowBox[{
     "we", " ", "only", " ", "integrate", " ", "up", " ", "to", " ", "t"}], 
     "=", "\[Tau]0"}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intPoly", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     SuperscriptBox["aPoly", "2"], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "\[Tau]0"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<poly: \>\"", ",", " ", "intPoly", ",", " ", "\"\<=\>\"", ",", 
   RowBox[{"intPoly", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intSin2", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     SuperscriptBox["aSin2", "2"], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "\[Tau]0"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<sin2: \>\"", ",", " ", "intSin2", ",", " ", "\"\<=\>\"", ",", 
   RowBox[{"intSin2", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"intGauss", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     SuperscriptBox["aGauss", "2"], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "\[Infinity]"}], ",", "\[Tau]0"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{
   "\"\<gauss: \>\"", ",", " ", "intGauss", ",", " ", "\"\<=\>\"", ",", 
    RowBox[{"intGauss", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "ratio", " ", "of", " ", "the", " ", "integrals", " ", "from", 
    " ", "this", " ", "notebook"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"intSin2", "/", "intPoly"}], "//", "N"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "ratio", " ", "of", " ", "the", " ", "integrals", " ", "from", 
    " ", "the", " ", "paper"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"0.375", "/", "0.392"}]}], "Input",
 CellChangeTimes->{{3.880100812872098*^9, 3.880100821438917*^9}, {
  3.880100868368412*^9, 3.880100870695248*^9}, {3.880100935674311*^9, 
  3.8801009382441597`*^9}, {3.880101006896936*^9, 3.880101096756252*^9}, {
