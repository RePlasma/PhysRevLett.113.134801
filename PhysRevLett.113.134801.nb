Cell[TextData[{
 "(In the units chosen in the paper, the classical electron radius, present \
in the Thompson cross section, is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"re", "=", "  ", 
    FractionBox[
     SuperscriptBox["e", "2"], 
     RowBox[{"m", " ", 
      SuperscriptBox["c", "2"]}]], " "}], TraditionalForm]],ExpressionUUID->
  "07cb13f8-2f8d-4539-a64a-ca9a7426520e"],
 "while in SI ",
 Cell[BoxData[
  RowBox[{"re", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"4", "\[Pi]", " ", "\[Epsilon]0"}]], "  ", 
    FractionBox[
     SuperscriptBox["e", "2"], 
     RowBox[{"m", " ", 
      SuperscriptBox["c", "2"]}]]}]}]],ExpressionUUID->
  "b16d0a48-31fa-4e5e-a722-1f099e4ddad0"],
 ")"
}], "Text",
 CellChangeTimes->{{3.87738900175957*^9, 
  3.877389158882521*^9}},ExpressionUUID->"d133c1cd-5a42-4c8f-b345-\
ad3622642c54"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "LP", " ", "PW", " ", "laser", " ", "colliding", " ", "against", " ", "a", 
    " ", "relativistic", " ", "electron"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{
    "\[Gamma]", ",", "\[Gamma]f", ",", "\[Gamma]0", ",", "k", ",", "k3", ",", 
     "\[Eta]", ",", "EGeV", ",", "\[Tau]0", ",", "\[Tau]0fs", ",", "e", ",", 
     "m", ",", "c", ",", "\[Lambda]", ",", "a0", ",", "\[Omega]0", ",", 
     "\[CapitalDelta]EE", ",", "\[Chi]", ",", "\[CapitalDelta]EE\[Chi]", ",", 
     "\[Epsilon]0"}], "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"equation", " ", "3"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Gamma]f", "=", 
     RowBox[{"\[Gamma]0", "/", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"k", " ", "\[Gamma]0"}]}], ")"}]}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"[", "]"}], " ", "final", " ", "electron", " ", "energy"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k3", "=", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"4", "\[Pi]", " ", "\[Epsilon]0"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Cos", "[", "\[Pi]", "]"}]}], ")"}], "2"], 
      FractionBox["\[Eta]", "3"], 
      FractionBox[
       RowBox[{
        SuperscriptBox["e", "2"], 
        SuperscriptBox["\[Omega]0", "2"]}], 
       RowBox[{"m", " ", 
        SuperscriptBox["c", "3"]}]], 
      SuperscriptBox["a0", "2"], "\[Tau]0"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"[", "]"}], " ", "CRR", " ", "k", " ", "factor", " ", "from", 
     " ", "equation", " ", "3"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k", "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Cos", "[", "\[Pi]", "]"}]}], ")"}], "2"], "3.2", " ", 
      SuperscriptBox["10", 
       RowBox[{"-", "5"}]], 
      RowBox[{"(", 
       RowBox[{"\[CapitalIota]", " ", 
        SuperscriptBox["10", 
         RowBox[{"-", "22"}]]}], ")"}], "\[Tau]0fs"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"[", "]"}], " ", "CRR", " ", "k", " ", "factor", " ", 
     "Engineering", " ", "formula"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalDelta]EE", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Gamma]0", "-", "\[Gamma]f"}], ")"}], "/", "\[Gamma]0"}]}], 
    ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"[", "]"}], " ", "0"}], "<=", 
     RowBox[{"energy", " ", "loss"}], "<=", "1"}], " ", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"\[Chi]", "=", 
     RowBox[{"1", ":", " ", 
      RowBox[{
       RowBox[{"\[Chi]", "~", "2"}], " ", "\[Gamma]0", " ", 
       RowBox[{"a0", "/", "aS"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"\[Gamma]f", "==", 
        RowBox[{"\[Gamma]0", "/", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"k", " ", "\[Gamma]0"}]}], ")"}]}]}], ",", "\[Gamma]0"}], 
      "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Gamma]", "=", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{"1", "==", 
         RowBox[{"2", "\[Gamma]", " ", 
          RowBox[{"a0", "/", 
           RowBox[{"(", "411823", ")"}]}]}]}], ",", "\[Gamma]"}], "]"}], "[", 
      
      RowBox[{"[", 
